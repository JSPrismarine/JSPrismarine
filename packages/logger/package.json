{
    "name": "@jsprismarine/logger",
    "version": "0.14.1",
    "description": "JSPrismarine logger and utilities",
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "type": "module",
    "files": [
        "dist",
        "CHANGELOG.md",
        "README.md"
    ],
    "main": "./dist/index.cjs.cjs",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js",
            "module": "./dist/index.es.js",
            "require": "./dist/index.cjs.cjs"
        },
        "./*": {
            "types": "./dist/*.d.ts",
            "import": "./dist/*.es.js",
            "module": "./dist/*.es.js",
            "require": "./dist/*.cjs.cjs"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "clean": "rimraf dist jsp *.tsbuildinfo vite.config.ts.timestamp-* .tsup .turbo",
        "build": "vite build",
        "build:watch": "vite build --watch",
        "typecheck": "tsc -noEmit"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/JSPrismarine/JSPrismarine.git"
    },
    "keywords": [
        "jsprismarine",
        "errors"
    ],
    "author": "JSPrismarine",
    "license": "MIT",
    "homepage": "https://github.com/JSPrismarine/JSPrismarine/tree/master/packages/errors",
    "devDependencies": {
        "@types/node": "24.13.3",
        "glob": "13.0.6",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "vite": "8.1.3",
        "vitest": "4.1.9"
    },
    "dependencies": {
        "@jsprismarine/color-parser": "workspace:*",
        "winston": "3.19.0",
        "winston-transport": "4.9.0"
    }
}
